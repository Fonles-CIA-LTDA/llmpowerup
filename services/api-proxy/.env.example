# ============================================
# LLMPowerUp — API Proxy Configuration
# ============================================
# Copy this file to .env and fill in the values.

# Proxy server port
PORT=4000

# Rust backend URL
RUST_BACKEND=http://localhost:3001

# OpenRouter base URL (don't change unless using a custom endpoint)
OPENROUTER_BASE=https://openrouter.ai/api/v1

# Supabase connection (for auth, rate limiting, usage tracking)
# Find in: Supabase > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key

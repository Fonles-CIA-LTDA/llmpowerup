# ============================================
# LLMPowerUp — Dashboard Configuration
# ============================================
# Copy this file to .env.local and fill in the values.

# Supabase (public keys — safe to expose in browser)
# Find in: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key

# Supabase service role key (server-side only, for API routes)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# API proxy URL (where the dashboard's API routes forward to)
# Default: http://localhost:4000 (the API proxy)
# Or point directly to the Rust backend: http://localhost:3001
AGENT_BACKEND_URL=http://localhost:4000

# Public API URL (shown in documentation examples)
NEXT_PUBLIC_API_URL=http://localhost:4000
